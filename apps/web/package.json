{
  "name": "@smagicalsub/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply smagicalsub --local",
    "db:migrate:remote": "wrangler d1 migrations apply smagicalsub --remote"
  },
  "dependencies": {
    "@smagicalsub/shared": "workspace:*",
    "@tanstack/react-query": "^5.90.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.10.0",
    "@cloudflare/workers-types": "latest",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
